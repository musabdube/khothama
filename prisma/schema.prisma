
generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  USER
  ADMIN
}

enum UserStatus {
  ACTIVE
  BANNED
  PENDING
}

enum ProductStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
  OUT_OF_STOCK
}

enum VariationType {
  SIZE
  COLOR
  SHADE
  MATERIAL
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
  REFUNDED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
  REFUNDED
  PARTIALLY_REFUNDED
}

enum AddressType {
  BILLING
  SHIPPING
}

enum PaymentType {
  CREDIT_CARD
  DEBIT_CARD
  PAYPAL
  APPLE_PAY
  GOOGLE_PAY
  BANK_TRANSFER
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  FLAGGED
}

enum ProductReportStatus {
  PENDING
  REVIEWED
  DISMISSED
}

enum DiscountType {
  PERCENTAGE
  FIXED_AMOUNT
  FREE_SHIPPING
  BUY_X_GET_Y
}

enum DeliveryType {
  STANDARD
  EXPRESS
  SAME_DAY
  PICKUP
}

enum PromoCodeType {
  PERCENTAGE
  FIXED_USD
}

enum OfferStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum NotificationType {
  OFFER_RECEIVED
  ORDER_RECEIVED
  ADMIN_NEW_PRODUCT
  ADMIN_FLAGGED_PRODUCT
}

enum AccessRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  password      String
  role          UserRole  @default(USER)
  status        UserStatus @default(ACTIVE)
  emailVerified DateTime?
  image         String?
  avatar        String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  reviews       Review[]
  wishlist      WishlistItem[]
  addresses     Address[]
  paymentMethods PaymentMethod[]
  tags          UserTag[] @relation("UserTags")
  sellerProducts Product[] @relation("SellerProducts")
  productReports ProductReport[]
  conversationsAsBuyer Conversation[] @relation("ConversationBuyer")
  conversationsAsSeller Conversation[] @relation("ConversationSeller")
  sentMessages Message[] @relation("ConversationMessageSender")
  sentProductOffers ProductOffer[] @relation("ProductOfferBuyer")
  receivedProductOffers ProductOffer[] @relation("ProductOfferSeller")
  productPromoCodes ProductPromoCode[] @relation("ProductPromoCodeSeller")
  supportConversationsAsUser SupportConversation[] @relation("SupportConversationUser")
  supportConversationsAsAdmin SupportConversation[] @relation("SupportConversationAdmin")
  supportSentMessages SupportMessage[] @relation("SupportMessageSender")
  notifications Notification[] @relation("UserNotifications")
  productRequests ProductRequest[] @relation("UserProductRequests")
  requestPageAccess RequestPageAccess? @relation("UserRequestPageAccess")
  passwordResetToken  String?
  passwordResetExpiry DateTime?
  requestConversationsAsRequester ProductRequestConversation[] @relation("ProductRequestConversationRequester")
  requestConversationsAsResponder ProductRequestConversation[] @relation("ProductRequestConversationResponder")
  sentProductRequestMessages ProductRequestMessage[] @relation("ProductRequestMessageSender")
  accessRequest AccessRequest? @relation("UserAccessRequest")
  ratingsGiven    UserRating[]  @relation("RatingsGiven")
  ratingsReceived UserRating[]  @relation("RatingsReceived")

  @@map("users")
}

model Product {
  id            String         @id @default(cuid())
  name          String
  description   String
  price         Float
  salePrice     Float?
  sku           String         @unique
  slug          String         @unique
  status        ProductStatus  @default(DRAFT)
  stock         Int            @default(0)
  weight        Float?
  dimensions    String?
  brand         String?
  material      String?
  fabric        String?
  skinType      String[]
  colors        String[]
  sizes         String[]
  shades        String[]
  ingredients   String[]
  usageTips     String[]
  tags          String[]
  popularity    Int            @default(0)
  releaseDate   DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  sellerId      String?
  seller        User?          @relation("SellerProducts", fields: [sellerId], references: [id])

  category      Category       @relation(fields: [categoryId], references: [id])
  categoryId    String
  brandId       String?
  brandRef      Brand?         @relation(fields: [brandId], references: [id])
  images        ProductImage[]
  variations    ProductVariation[]
  orderItems    OrderItem[]
  reviews       Review[]
  wishlistItems WishlistItem[]
  reports       ProductReport[]
  conversations Conversation[]
  offers        ProductOffer[]
  promoCodes    ProductPromoCode[]
  seo           ProductSEO?

  @@map("products")
}

model Brand {
  id          String    @id @default(cuid())
  name        String
  slug        String    @unique
  isActive    Boolean   @default(true)
  sortOrder   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  products    Product[]

  @@unique([name])
  @@map("brands")
}

model Category {
  id          String      @id @default(cuid())
  name        String
  description String?
  slug        String      @unique
  image       String?
  parentId    String?
  isActive    Boolean     @default(true)
  sortOrder   Int         @default(0)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  parent      Category?   @relation("CategoryTree", fields: [parentId], references: [id])
  children    Category[]  @relation("CategoryTree")
  products    Product[]
  seo         CategorySEO?

  @@map("categories")
}

model ProductImage {
  id        String   @id @default(cuid())
  url       String
  alt       String?
  isPrimary Boolean  @default(false)
  sortOrder Int      @default(0)

  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  @@map("product_images")
}

model ProductVariation {
  id        String         @id @default(cuid())
  type      VariationType
  name      String
  value     String
  price     Float?
  stock     Int?
  sku       String?
  isActive  Boolean        @default(true)

  product   Product        @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  @@map("product_variations")
}

model DeliveryMethod {
  id            String       @id @default(cuid())
  name          String
  type          DeliveryType @default(STANDARD)
  description   String?
  price         Float        @default(0)
  estimatedDays Int?
  isActive      Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  orders        Order[]

  @@map("delivery_methods")
}

model Order {
  id                String         @id @default(cuid())
  orderNumber       String         @unique
  status            OrderStatus    @default(PENDING)
  subtotal          Float
  tax               Float          @default(0)
  shipping          Float          @default(0)
  discount          Float          @default(0)
  total             Float
  currency          String         @default("USD")
  paymentStatus     PaymentStatus  @default(PENDING)
  paymentMethod     String?
  notes             String?
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  user              User           @relation(fields: [userId], references: [id])
  userId            String
  deliveryMethod    DeliveryMethod? @relation(fields: [deliveryMethodId], references: [id])
  deliveryMethodId  String?
  items             OrderItem[]
  address           OrderAddress?
  statusHistory     OrderStatusHistory[]

  @@map("orders")
}

model OrderItem {
  id        String   @id @default(cuid())
  quantity  Int
  status    OrderStatus @default(PENDING)
  trackingNumber String?
  estimatedDelivery DateTime?
  price     Float
  total     Float

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String
  product   Product  @relation(fields: [productId], references: [id])
  productId String

  @@map("order_items")
}

model OrderAddress {
  id        String   @id @default(cuid())
  firstName String
  lastName  String
  company   String?
  address1  String
  address2  String?
  city      String
  state     String
  zipCode   String
  country   String
  phone     String?

  order     Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String   @unique

  @@map("order_addresses")
}

model OrderStatusHistory {
  id        String      @id @default(cuid())
  status    OrderStatus
  notes     String?
  createdAt DateTime    @default(now())

  order     Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderId   String

  @@map("order_status_history")
}

model Address {
  id        String      @id @default(cuid())
  type      AddressType @default(SHIPPING)
  firstName String
  lastName  String
  company   String?
  address1  String
  address2  String?
  city      String
  state     String
  zipCode   String
  country   String
  phone     String?
  isDefault Boolean     @default(false)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String

  @@map("addresses")
}

model PaymentMethod {
  id          String      @id @default(cuid())
  type        PaymentType
  provider    String
  last4       String?
  brand       String?
  expiryMonth Int?
  expiryYear  Int?
  isDefault   Boolean     @default(false)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId      String

  @@map("payment_methods")
}

model Review {
  id           String       @id @default(cuid())
  rating       Int
  title        String?
  content      String
  status       ReviewStatus @default(PENDING)
  isVerified   Boolean      @default(false)
  helpfulCount Int          @default(0)
  reportCount  Int          @default(0)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId       String
  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    String

  @@map("reviews")
}

model WishlistItem {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  userId    String
  product   Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId String

  @@unique([userId, productId])
  @@map("wishlist_items")
}

model Discount {
  id             String       @id @default(cuid())
  name           String
  code           String       @unique
  type           DiscountType
  value          Float
  minOrderAmount Float?
  maxUses        Int?
  usedCount      Int          @default(0)
  isActive       Boolean      @default(true)
  startDate      DateTime
  endDate        DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@map("discounts")
}

model ProductOffer {
  id           String      @id @default(cuid())
  offeredPrice Float
  note         String?
  status       OfferStatus @default(PENDING)
  sellerNote   String?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  respondedAt  DateTime?

  product      Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId    String
  buyer        User        @relation("ProductOfferBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  buyerId      String
  seller       User        @relation("ProductOfferSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  sellerId     String

  rating       UserRating?

  @@index([productId, status])
  @@index([buyerId, createdAt])
  @@index([sellerId, status, createdAt])
  @@map("product_offers")
}

model ProductPromoCode {
  id         String       @id @default(cuid())
  code       String
  type       PromoCodeType
  value      Float
  isActive   Boolean      @default(true)
  startsAt   DateTime     @default(now())
  endsAt     DateTime?
  maxUses    Int?
  usedCount  Int          @default(0)
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt

  product    Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String
  seller     User         @relation("ProductPromoCodeSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  sellerId   String

  @@unique([productId, code])
  @@index([sellerId, createdAt])
  @@index([productId, isActive])
  @@map("product_promo_codes")
}

model Notification {
  id          String           @id @default(cuid())
  type        NotificationType
  title       String
  message     String
  link        String?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  recipient   User             @relation("UserNotifications", fields: [recipientId], references: [id], onDelete: Cascade)
  recipientId String

  @@index([recipientId, createdAt])
  @@index([recipientId, readAt])
  @@map("notifications")
}

model Conversation {
  id            String    @id @default(cuid())
  productId     String
  buyerId       String
  sellerId      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  lastMessageAt DateTime  @default(now())

  product       Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  buyer         User      @relation("ConversationBuyer", fields: [buyerId], references: [id], onDelete: Cascade)
  seller        User      @relation("ConversationSeller", fields: [sellerId], references: [id], onDelete: Cascade)
  messages      Message[]

  @@unique([productId, buyerId, sellerId])
  @@index([buyerId, lastMessageAt])
  @@index([sellerId, lastMessageAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime     @default(now())
  readAt         DateTime?

  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("ConversationMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("messages")
}

model SupportConversation {
  id            String           @id @default(cuid())
  userId        String
  adminId       String?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt
  lastMessageAt DateTime         @default(now())

  user          User             @relation("SupportConversationUser", fields: [userId], references: [id], onDelete: Cascade)
  admin         User?            @relation("SupportConversationAdmin", fields: [adminId], references: [id], onDelete: SetNull)
  messages      SupportMessage[]

  @@unique([userId])
  @@index([adminId, lastMessageAt])
  @@index([lastMessageAt])
  @@map("support_conversations")
}

model SupportMessage {
  id             String              @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime            @default(now())
  readAt         DateTime?

  conversation   SupportConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User                @relation("SupportMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("support_messages")
}

model ProductReport {
  id         String              @id @default(cuid())
  reason     String
  details    String?
  status     ProductReportStatus @default(PENDING)
  adminNote  String?
  createdAt  DateTime            @default(now())
  updatedAt  DateTime            @updatedAt
  reviewedAt DateTime?

  reporter   User                @relation(fields: [reporterId], references: [id], onDelete: Cascade)
  reporterId String
  product    Product             @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId  String

  @@index([status])
  @@index([productId])
  @@index([reporterId])
  @@map("product_reports")
}

model UserTag {
  id    String   @id @default(cuid())
  name  String
  color String?

  users User[]   @relation("UserTags")

  @@map("user_tags")
}

model ProductSEO {
  id              String    @id @default(cuid())
  title           String?
  metaDescription String?
  metaKeywords    String?
  slug            String    @unique
  canonicalUrl    String?
  noIndex         Boolean   @default(false)
  noFollow        Boolean   @default(false)

  product         Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  productId       String    @unique

  @@map("product_seo")
}

model CategorySEO {
  id              String    @id @default(cuid())
  title           String?
  metaDescription String?
  metaKeywords    String?
  slug            String    @unique
  canonicalUrl    String?
  noIndex         Boolean   @default(false)
  noFollow        Boolean   @default(false)

  category        Category  @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId      String    @unique

  @@map("category_seo")
}

model Page {
  id              String    @id @default(cuid())
  title           String
  slug            String    @unique
  content         String?
  metaTitle       String?
  metaDescription String?
  metaKeywords    String?
  isPublished     Boolean   @default(false)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@map("pages")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model ProductRequest {
  id          String   @id @default(cuid())
  name        String
  description String
  image       String?
  category    String?
  budget      String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation("UserProductRequests", fields: [userId], references: [id], onDelete: Cascade)
  userId      String
  conversations ProductRequestConversation[]

  @@index([userId, createdAt])
  @@map("product_requests")
}

model ProductRequestConversation {
  id               String   @id @default(cuid())
  productRequestId String
  requesterId      String
  responderId      String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  lastMessageAt    DateTime @default(now())

  productRequest   ProductRequest @relation(fields: [productRequestId], references: [id], onDelete: Cascade)
  requester        User           @relation("ProductRequestConversationRequester", fields: [requesterId], references: [id], onDelete: Cascade)
  responder        User           @relation("ProductRequestConversationResponder", fields: [responderId], references: [id], onDelete: Cascade)
  messages         ProductRequestMessage[]

  @@unique([productRequestId, requesterId, responderId])
  @@index([requesterId, lastMessageAt])
  @@index([responderId, lastMessageAt])
  @@index([productRequestId, lastMessageAt])
  @@map("product_request_conversations")
}

model ProductRequestMessage {
  id             String   @id @default(cuid())
  conversationId String
  senderId       String
  content        String
  createdAt      DateTime @default(now())
  readAt         DateTime?

  conversation   ProductRequestConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User                       @relation("ProductRequestMessageSender", fields: [senderId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([senderId])
  @@map("product_request_messages")
}

model RequestPageAccess {
  id        String    @id @default(cuid())
  expiresAt DateTime
  grantedAt DateTime  @default(now())

  user      User      @relation("UserRequestPageAccess", fields: [userId], references: [id], onDelete: Cascade)
  userId    String    @unique

  @@index([userId, expiresAt])
  @@map("request_page_access")
}

model AccessRequest {
  id        String              @id @default(cuid())
  status    AccessRequestStatus @default(PENDING)
  message   String?
  createdAt DateTime            @default(now())
  updatedAt DateTime            @updatedAt

  user      User                @relation("UserAccessRequest", fields: [userId], references: [id], onDelete: Cascade)
  userId    String              @unique

  @@map("access_requests")
}

model UserRating {
  id        String   @id @default(cuid())
  rating    Int      // 1–5
  comment   String?
  createdAt DateTime @default(now())

  rater     User     @relation("RatingsGiven", fields: [raterId], references: [id], onDelete: Cascade)
  raterId   String
  rated     User     @relation("RatingsReceived", fields: [ratedId], references: [id], onDelete: Cascade)
  ratedId   String

  offer     ProductOffer @relation(fields: [offerId], references: [id], onDelete: Cascade)
  offerId   String       @unique  // one rating per accepted offer

  @@index([ratedId, createdAt])
  @@index([raterId, createdAt])
  @@map("user_ratings")
}
